{
  "navigationFallback": {
    "rewrite": "/index.html",
    "exclude": ["/api/*", "/assets/*", "/design-assets/*", "/favicon.svg", "/icons.svg"]
  },
  "routes": [
    {
      "route": "/design-assets/*",
      "headers": {
        "Cache-Control": "public, max-age=31536000, immutable"
      }
    },
    {
      "route": "/protocol",
      "redirect": "/",
      "statusCode": 302
    },
    {
      "route": "/protocol/*",
      "redirect": "/",
      "statusCode": 302
    },
    {
      "route": "/admin/*",
      "allowedRoles": ["admin"]
    },
    {
      "route": "/api/saves/*",
      "allowedRoles": ["admin"]
    },
    {
      "route": "/api/analysis/session",
      "allowedRoles": ["admin"]
    }
  ],
  "responseOverrides": {
    "401": {
      "redirect": "/.auth/login/github",
      "statusCode": 302
    }
  },
  "globalHeaders": {
    "X-Content-Type-Options": "nosniff",
    "Referrer-Policy": "strict-origin-when-cross-origin"
  },
  "mimeTypes": {
    ".json": "application/json"
  }
}
